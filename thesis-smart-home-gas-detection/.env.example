# Global
COMPOSE_PROJECT_NAME=thesis-gas-detection
TZ=Asia/Ho_Chi_Minh

# MQTT
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_TOPIC_SENSOR=sensors/gas

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC_RAW_GAS=gas.raw.sensor
KAFKA_TOPIC_ALERT=gas.alert.events

# InfluxDB 2.7
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=thesis-org
INFLUXDB_BUCKET_GAS=gas_sensor_data
INFLUXDB_BUCKET_ALERT=gas_alerts
INFLUXDB_TOKEN=thesis-super-token
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=admin123456

# PostgreSQL 16
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gas_metadata
POSTGRES_USER=gas_admin
POSTGRES_PASSWORD=gas_admin_123

# Node.js backend
NODE_ENV=development
API_PORT=3000
JWT_SECRET=replace_me

# Frontend
FRONTEND_PORT=8080
# ⚠ BACKEND_BASE_URL is rendered into browser HTML — must be accessible from
#   the user's browser (host machine), NOT from inside Docker.
#   Use http://localhost:3000 (or your server IP if deploying remotely).
BACKEND_BASE_URL=http://localhost:3000

# Model paths  (Docker volume: ./processing → /app inside processing-engine)
LSTM_MODEL_PATH=/app/ml/lstm/best_lstm_uci.keras
RL_MODEL_PATH=/app/ml/rl/ppo_gas_agent.zip

# LSTM thresholds
LSTM_ALERT_THRESHOLD=0.7
LSTM_WARNING_THRESHOLD=0.4
