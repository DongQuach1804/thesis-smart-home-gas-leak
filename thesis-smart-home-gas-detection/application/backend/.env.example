NODE_ENV=development
API_PORT=3000

# CORS — comma-separated origins allowed to call the API from the browser
BACKEND_BASE_URL=http://localhost:3000

# InfluxDB
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=thesis-super-token
INFLUXDB_ORG=thesis-org
INFLUXDB_BUCKET_GAS=gas_sensor_data

# Kafka
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_ALERT=gas.alert.events
KAFKA_TOPIC_RAW_GAS=gas.raw.sensor

# PostgreSQL — device metadata + alert history
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gas_metadata
POSTGRES_USER=gas_admin
POSTGRES_PASSWORD=gas_admin_123

# Demo / fallback — when true, synthesises plausible sensor data if Influx is empty,
# so the dashboard is always usable for demo purposes.
DEMO_FALLBACK=true

# Alert thresholds (ppm) — used for mock data labelling and frontend KPI colouring
GAS_PPM_WARNING=400
GAS_PPM_ALERT=700
