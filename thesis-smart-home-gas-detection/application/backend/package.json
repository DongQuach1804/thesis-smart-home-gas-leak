  "devDependencies": {
    "@types/cors":    "^2.8.17",
    "@types/ejs":     "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/jest":    "^29.5.12",
    "@types/node":    "^22.7.4",
    "@types/pg":      "^8.11.10",
    "eslint":         "^9.11.1",
    "jest":           "^29.7.0",
    "nodemon":        "^3.1.4",
